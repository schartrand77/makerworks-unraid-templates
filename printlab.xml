<?xml version="1.0"?>
<Container version="2">
  <Name>PrintLab</Name>
  <Repository>ghcr.io/schartrand77/printlab:latest</Repository>
  <Registry>https://github.com/schartrand77/printlab/pkgs/container/printlab</Registry>
  <Network>makerworks-net</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/schartrand77/printlab/issues</Support>
  <Project>https://github.com/schartrand77/printlab</Project>
  <Overview><![CDATA[PrintLab is a standalone dashboard and API for Bambu printers with multi-printer monitoring, printer job tracking, MakerWorks handoff, StockWorks filament lookup, and optional timelapse upload support.]]></Overview>
  <Category>Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/schartrand77/makerworks-unraid-templates/main/printlab.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/schartrand77/printlab/main/public/icon-192.png</Icon>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <Requires>Mapped /data and /config paths, printer credentials or PRINTERS_JSON, admin password hash, session secret, and Docker network makerworks-net.</Requires>

  <Config Name="Web UI Port" Target="8080" Default="8983" Mode="tcp" Description="Host port for the PrintLab web UI." Type="Port" Display="always" Required="true" Mask="false">8983</Config>
  <Config Name="Data Path" Target="/data" Default="/mnt/user/appdata/printlab/data" Mode="rw" Description="Persistent PrintLab data, cache, submitted jobs, and successful G-code records." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/printlab/data</Config>
  <Config Name="Config Path" Target="/config" Default="/mnt/user/appdata/printlab/config" Mode="rw" Description="Optional PrintLab config.json and file-based secret directory." Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/printlab/config</Config>
  <Config Name="Timezone" Target="TZ" Default="Etc/UTC" Mode="" Description="Container timezone." Type="Variable" Display="advanced" Required="false" Mask="false">Etc/UTC</Config>
  <Config Name="Log Level" Target="LOG_LEVEL" Default="INFO" Mode="" Description="Application log level." Type="Variable" Display="advanced" Required="false" Mask="false">INFO</Config>
  <Config Name="PRINTERS_JSON" Target="PRINTERS_JSON" Default="" Mode="" Description="Optional multi-printer JSON array. If set, overrides single PRINTER_* values." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="Printer Name" Target="PRINTER_NAME" Default="" Mode="" Description="Friendly name for single-printer mode." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="Printer Host" Target="PRINTER_HOST" Default="" Mode="" Description="Single-printer LAN IP or hostname." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="Printer Serial" Target="PRINTER_SERIAL" Default="" Mode="" Description="Single-printer serial number." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="Printer Access Code" Target="PRINTER_ACCESS_CODE" Default="" Mode="" Description="Single-printer LAN access code." Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="Printer Device Type" Target="PRINTER_DEVICE_TYPE" Default="unknown" Mode="" Description="Printer device type override." Type="Variable" Display="advanced" Required="false" Mask="false">unknown</Config>
  <Config Name="Local MQTT" Target="PRINTER_LOCAL_MQTT" Default="true" Mode="" Description="Use local MQTT mode." Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
  <Config Name="Enable Camera" Target="PRINTER_ENABLE_CAMERA" Default="true" Mode="" Description="Enable camera retrieval." Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
  <Config Name="Disable SSL Verify" Target="PRINTER_DISABLE_SSL_VERIFY" Default="false" Mode="" Description="Disable SSL verification for printer/cloud calls." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="File Cache Path" Target="FILE_CACHE_PATH" Default="/data/cache" Mode="" Description="Internal cache path." Type="Variable" Display="advanced" Required="false" Mask="false">/data/cache</Config>
  <Config Name="Print Cache Count" Target="PRINT_CACHE_COUNT" Default="1" Mode="" Description="Cached print records count." Type="Variable" Display="advanced" Required="false" Mask="false">1</Config>
  <Config Name="Timelapse Cache Count" Target="TIMELAPSE_CACHE_COUNT" Default="1" Mode="" Description="Cached timelapse records count." Type="Variable" Display="advanced" Required="false" Mask="false">1</Config>
  <Config Name="Bambu Region" Target="BAMBU_REGION" Default="" Mode="" Description="Optional Bambu cloud region." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="Bambu Email" Target="BAMBU_EMAIL" Default="" Mode="" Description="Optional Bambu cloud email." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="Bambu Username" Target="BAMBU_USERNAME" Default="" Mode="" Description="Optional Bambu cloud username." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="Bambu Auth Token" Target="BAMBU_AUTH_TOKEN" Default="" Mode="" Description="Optional Bambu cloud auth token." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="Require Auth" Target="REQUIRE_AUTH" Default="true" Mode="" Description="Require login for UI and API access." Type="Variable" Display="always" Required="true" Mask="false">true</Config>
  <Config Name="Admin Username" Target="ADMIN_USERNAME" Default="admin" Mode="" Description="Admin login username." Type="Variable" Display="always" Required="true" Mask="false">admin</Config>
  <Config Name="Admin Email" Target="ADMIN_EMAIL" Default="" Mode="" Description="Optional admin login email." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="Admin Password Hash" Target="ADMIN_PASSWORD_HASH" Default="" Mode="" Description="Required hashed admin password. Generate with PrintLab scripts/hash_password.py." Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="Session Secret" Target="SESSION_SECRET" Default="" Mode="" Description="Required long random secret used to sign session cookies." Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="Session Cookie Secure" Target="SESSION_COOKIE_SECURE" Default="false" Mode="" Description="Set true when serving behind HTTPS." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="MakerWorks Base URL" Target="MAKERWORKS_BASE_URL" Default="http://MakerWorks-v2:3000" Mode="" Description="MakerWorks API base URL on makerworks-net." Type="Variable" Display="advanced" Required="false" Mask="false">http://MakerWorks-v2:3000</Config>
  <Config Name="MakerWorks API Key" Target="MAKERWORKS_API_KEY" Default="" Mode="" Description="Optional MakerWorks API key." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="MakerWorks Bearer Token" Target="MAKERWORKS_BEARER_TOKEN" Default="" Mode="" Description="Optional MakerWorks bearer token." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="MakerWorks Auth Header" Target="MAKERWORKS_AUTH_HEADER" Default="X-API-Key" Mode="" Description="Header used for MakerWorks API key." Type="Variable" Display="advanced" Required="false" Mask="false">X-API-Key</Config>
  <Config Name="MakerWorks Webhook Secret" Target="MAKERWORKS_WEBHOOK_SECRET" Default="" Mode="" Description="Shared secret for callbacks sent to MakerWorks." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="MakerWorks Submit API Key" Target="MAKERWORKS_SUBMIT_API_KEY" Default="" Mode="" Description="API key accepted for MakerWorks submit boundary routes." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="MakerWorks Allowed Paths" Target="MAKERWORKS_ALLOWED_PATHS" Default="/health,/api/models" Mode="" Description="Comma-separated allowlist for MakerWorks proxy paths." Type="Variable" Display="advanced" Required="false" Mask="false">/health,/api/models</Config>
  <Config Name="MakerWorks Job Callback Enabled" Target="MAKERWORKS_JOB_CALLBACK_ENABLED" Default="false" Mode="" Description="Send job status callbacks to MakerWorks." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="MakerWorks Job Callback Path Template" Target="MAKERWORKS_JOB_CALLBACK_PATH_TEMPLATE" Default="" Mode="" Description="Callback path, e.g. /api/printlab/jobs/{job_id}." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="StockWorks Base URL" Target="STOCKWORKS_BASE_URL" Default="http://StockWorks:8000" Mode="" Description="Optional StockWorks API base URL." Type="Variable" Display="advanced" Required="false" Mask="false">http://StockWorks:8000</Config>
  <Config Name="StockWorks API Key" Target="STOCKWORKS_API_KEY" Default="" Mode="" Description="Optional StockWorks API key." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="YouTube Upload Enabled" Target="YOUTUBE_UPLOAD_ENABLED" Default="false" Mode="" Description="Enable automatic timelapse uploads to YouTube." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="YouTube Client ID" Target="YOUTUBE_CLIENT_ID" Default="" Mode="" Description="OAuth client ID for YouTube uploads." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="YouTube Client Secret" Target="YOUTUBE_CLIENT_SECRET" Default="" Mode="" Description="OAuth client secret for YouTube uploads." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="YouTube Refresh Token" Target="YOUTUBE_REFRESH_TOKEN" Default="" Mode="" Description="OAuth refresh token for YouTube uploads." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
</Container>
